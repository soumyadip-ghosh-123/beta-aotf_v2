erDiagram

  USER {
    string id PK
    string name
    string email UK
    string phone
    string password_hash
    string role "guardian|teacher|freelancer|client|admin"
    boolean onboarding_completed
    boolean email_verified
    boolean phone_verified
    string avatar_url
    datetime last_login_at
    datetime created_at
    datetime updated_at
  }

  GUARDIAN {
    string id PK
    string user_id UK
    string address
    string city
    string state
    string pincode
    string preferred_gender "male|female|other"
    datetime created_at
    datetime updated_at
  }

  TEACHER {
    string id PK
    string user_id UK
    string teacher_id UK
    string gender
    date date_of_birth
    string qualification
    int experience_years
    string subjects "array"
    string classes "array"
    string boards "array"
    string preferred_locations "array"
    text bio
    string verification_status "pending|verified|rejected"
    boolean is_premium
    boolean registration_paid
    float rating
    int total_reviews
    int total_tuitions
    datetime created_at
    datetime updated_at
  }

  POST {
    string id PK
    string post_id UK
    string guardian_id FK
    string title
    string subject
    string class
    string board
    string preferred_gender
    float budget_min
    float budget_max
    string mode "online|offline|hybrid"
    string status "open|matched|closed|cancelled|hold"
    string approved_teacher_id FK
    datetime created_at
    datetime updated_at
  }

  APPLICATION {
    string id PK
    string application_id UK
    string post_id FK
    string teacher_id FK
    string status "pending|approved|declined|withdrawn|completed"
    float expected_fee
    datetime created_at
    datetime updated_at
  }

  CLIENT {
    string id PK
    string user_id UK
    string company_name
    string industry
    datetime created_at
    datetime updated_at
  }

  FREELANCER {
    string id PK
    string user_id UK
    string freelancer_id UK
    string skills "array"
    string verification_status
    float hourly_rate
    boolean is_premium
    datetime created_at
    datetime updated_at
  }

  PROJECT {
    string id PK
    string project_id UK
    string client_id FK
    string title
    string status "open|in_progress|completed|cancelled"
    float budget_min
    float budget_max
    datetime created_at
    datetime updated_at
  }

  PROJECT_APPLICATION {
    string id PK
    string project_id FK
    string freelancer_id FK
    string status
    datetime created_at
    datetime updated_at
  }

  JOB {
    string id PK
    string job_id UK
    string client_id FK
    string title
    string status "open|filled|closed|cancelled"
    datetime created_at
    datetime updated_at
  }

  JOB_APPLICATION {
    string id PK
    string job_id FK
    string freelancer_id FK
    string status
    datetime created_at
    datetime updated_at
  }

  ADMIN {
    string id PK
    string user_id UK
    string admin_level "super_admin|admin|moderator"
    datetime created_at
    datetime updated_at
  }

  INVOICE {
    string id PK
    string invoice_id UK
    string user_id FK
    float total_amount
    string status "pending|paid|failed|refunded"
    datetime created_at
  }

  PAYMENT {
    string id PK
    string payment_id UK
    string user_id FK
    string invoice_id FK
    float amount
    string status
    datetime created_at
  }

  FEEDBACK {
    string id PK
    string from_user_id FK
    string to_user_id FK
    int rating
    text review
    datetime created_at
  }

  AD {
    string id PK
    string ad_id UK
    string status "scheduled|active|inactive|expired"
    datetime created_at
  }

  ENQUIRY {
    string id PK
    string enquiry_id UK
    string user_type "guardian|client"
    string status "pending|contacted|lead_confirmed|closed"
    datetime created_at
  }

  SETTING {
    string id PK
    string key UK
    text value
    boolean is_public
    datetime created_at
  }

  %% ================= RELATIONSHIPS =================

  USER ||--|| GUARDIAN : has
  USER ||--|| TEACHER : has
  USER ||--|| CLIENT : has
  USER ||--|| FREELANCER : has
  USER ||--|| ADMIN : has

  GUARDIAN ||--o{ POST : creates
  POST ||--o{ APPLICATION : receives
  TEACHER ||--o{ APPLICATION : submits
  POST ||--|| TEACHER : approves

  CLIENT ||--o{ PROJECT : posts
  PROJECT ||--o{ PROJECT_APPLICATION : receives
  FREELANCER ||--o{ PROJECT_APPLICATION : applies

  CLIENT ||--o{ JOB : posts
  JOB ||--o{ JOB_APPLICATION : receives
  FREELANCER ||--o{ JOB_APPLICATION : applies

  USER ||--o{ INVOICE : billed
  USER ||--o{ PAYMENT : pays
  USER ||--o{ FEEDBACK : gives

  ADMIN ||--o{ AD : creates
  ADMIN ||--o{ ENQUIRY : handles
  ADMIN ||--o{ SETTING : updates